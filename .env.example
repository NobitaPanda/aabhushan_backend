PORT=5000
MONGO_URI=mongodb://localhost:27017/goldshop
JWT_SECRET=change_this_secret
NODE_ENV=development

# Frontend URL used for password reset links and allowed browser origins.
# In production this should be your real frontend domain.
FRONTEND_URL=http://localhost:5173

# Optional comma-separated list of extra allowed browser origins.
# Example:
# ALLOWED_ORIGINS=https://aabhushan.vercel.app,https://partner-frontend.vercel.app,https://*.vercel.app
ALLOWED_ORIGINS=

# Default internal account passwords synced on startup.
OWNER_PASSWORD=owner@123
MANAGER_PASSWORD=manager@123
INVENTORY_PASSWORD=inventory@123
MANUFACTURING_PASSWORD=manufacturing@123
SALES_PASSWORD=sales@123
KARIGAR_PASSWORD=karigar@123

# Demo products are inserted automatically when the Product collection is empty.
# This helps fresh deployments show products immediately.
SEED_DEFAULT_PRODUCTS=true

# SMTP configuration for OTP/reset/order emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
SMTP_SECURE=false
EMAIL_FROM=Aabhusan <your-email@example.com>

# Razorpay test mode
RAZORPAY_KEY_ID=rzp_test_example
RAZORPAY_KEY_SECRET=replace_with_test_secret

# Optional in-memory cache for public live metal rates
METAL_RATES_CACHE_MS=900000
